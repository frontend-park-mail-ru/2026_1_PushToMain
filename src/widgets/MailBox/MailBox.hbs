<div class="mail-tile">
    <div class="mail-header">
        <div class="mail-header__left-container"></div>
        <div class="mail-header__right-container">
            <p>1-50 из 369</p>
        </div>
    </div>
    <div class="mail-list">
        <div class="mail">
            <div class="checkbox-container"></div>
            <div class="mail-content">
                <span class="mail-theme">{{theme}}</span>
                <span class="mail-title">{{title}}</span>
            </div>
            <span class="mail-date">{{date}}</span>
        </div>
    </div>
</div>